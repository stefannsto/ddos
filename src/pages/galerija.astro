---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Galerija">
	<div class="page-content">
		<h1>Galerija</h1>
		<p class="intro">
			Pogledajte fotografije sa naših događaja, aktivnosti i zajedničkih momenata.
		</p>

		<div class="gallery-container">
			<div class="gallery-placeholder">
				<div class="placeholder-content">
					<div class="placeholder-icon">📷</div>
					<h2>Galerija je u pripremi</h2>
					<p>
						Uskoro ćemo dodati fotografije sa naših najzanimljivijih događaja i aktivnosti.
						Pratite nas na društvenim mrežama za najnovije ažuriranja!
					</p>
					<div class="social-links">
						<p><strong>Pratite nas:</strong></p>
						<ul>
							<li><a href="#" target="_blank">Facebook</a></li>
							<li><a href="#" target="_blank">Instagram</a></li>
							<li><a href="#" target="_blank">Twitter</a></li>
						</ul>
					</div>
				</div>
			</div>
		</div>

		<div class="gallery-info">
			<h3>Kako podijeliti svoje fotografije?</h3>
			<p>
				Ako imate zanimljive fotografije sa naših događaja, slobodno nam ih pošaljite na
				<strong>email@ddos.org</strong> i mi ćemo ih dodati u galeriju!
			</p>
		</div>
	</div>

	<style>
		.page-content {
			max-width: 900px;
		}

		h1 {
			color: #5a1b6d;
			margin-bottom: 20px;
			font-size: 42px;
		}

		.intro {
			font-size: 18px;
			color: #666;
			margin-bottom: 40px;
			line-height: 1.6;
		}

		.gallery-container {
			margin-bottom: 40px;
		}

		.gallery-placeholder {
			background: linear-gradient(135deg, #f5f5f5 0%, #eeeeee 100%);
			border: 2px dashed #5a1b6d;
			border-radius: 10px;
			padding: 60px 20px;
			text-align: center;
		}

		.placeholder-content h2 {
			color: #5a1b6d;
			margin-bottom: 15px;
			font-size: 28px;
		}

		.placeholder-icon {
			font-size: 60px;
			margin-bottom: 20px;
		}

		.placeholder-content p {
			color: #666;
			line-height: 1.6;
			margin-bottom: 25px;
			font-size: 16px;
		}

		.social-links {
			background: white;
			display: inline-block;
			padding: 20px 30px;
			border-radius: 8px;
			box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
		}

		.social-links p {
			margin: 0 0 15px 0;
			font-weight: 600;
		}

		.social-links ul {
			list-style: none;
			padding: 0;
			display: flex;
			gap: 20px;
			justify-content: center;
		}

		.social-links a {
			color: #5a1b6d;
			text-decoration: none;
			font-weight: 600;
			transition: color 0.3s ease;
		}

		.social-links a:hover {
			color: #7d3a98;
		}

		.gallery-info {
			background: white;
			padding: 30px;
			border-radius: 8px;
			box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
		}

		.gallery-info h3 {
			color: #5a1b6d;
			margin-bottom: 15px;
			font-size: 20px;
		}

		.gallery-info p {
			color: #666;
			line-height: 1.6;
		}
	</style>
</Layout>
